{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sigyn",
  "mainBinaryName": "sigyn-desktop",
  "version": "0.1.0",
  "identifier": "com.connorguy.sigyn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "sigyn",
        "width": 1480,
        "height": 940,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
